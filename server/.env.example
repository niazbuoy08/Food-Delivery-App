# Copy this file to `.env` and fill in real values. Never commit `.env`.

PORT=5000
NODE_ENV=development

# MongoDB Atlas connection string.
# Atlas -> Connect -> Drivers -> copy the string, then replace <password>.
# Keep the database name (`fooddelivery`) in the path.
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/fooddelivery?retryWrites=true&w=majority

# Signs admin login tokens. Any long random string; change it and every admin is logged out.
JWT_SECRET=replace-me-with-a-long-random-string
JWT_EXPIRES_IN=7d

# Where the React dev server runs. Used for CORS.
CLIENT_URL=http://localhost:5173

# Seeded admin account (`npm run seed`). Change the password before deploying.
ADMIN_EMAIL=admin@bistrolumiere.com
ADMIN_PASSWORD=admin123
ADMIN_NAME=Restaurant Manager
